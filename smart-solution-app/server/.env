# MongoDB Connection
# Replace with your MongoDB Compass connection string
# Example for local MongoDB Compass: mongodb://localhost:27017/smart-solution
# Example with auth: mongodb://username:password@localhost:27017/smart-solution
MONGODB_URI=mongodb://localhost:27017/smart-solution

# JWT Secret (change this to a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=5000

# Environment
NODE_ENV=development
